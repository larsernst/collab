POSTGRES_DB=collab
POSTGRES_USER=collab
POSTGRES_PASSWORD=replace-with-a-long-random-password
COLLAB_HTTP_PORT=8788
COLLAB_HTTP_BIND=0.0.0.0
# The following runtime settings are configurable in /admin/settings.
# Uncomment any value here to make it a global environment override; overridden
# settings are shown as locked in the admin UI.
# COLLAB_BROWSER_SECURE_COOKIES=false
# COLLAB_NATIVE_ACCESS_TTL_MINUTES=15
# COLLAB_NATIVE_REFRESH_TTL_DAYS=30
# COLLAB_WS_TICKET_TTL_SECONDS=30
# Byte sizes accept plain integers or binary-unit suffixes (e.g. 256MiB, 12 GiB).
# COLLAB_MAX_FILE_BYTES=256MiB
# COLLAB_MAX_IMPORT_BYTES=512MiB
# COLLAB_MAX_IMPORT_EXPANDED_BYTES=2GiB
# COLLAB_STORAGE_WARNING_BYTES=10GiB
# COLLAB_STORAGE_QUOTA_BYTES=0
# Coarse per-client-IP rate limits (operator-controlled, not in the admin UI).
# Set to 0 to disable. Clients are identified by the last X-Forwarded-For hop
# added by the trusted gateway.
# COLLAB_REST_RATE_LIMIT_PER_MINUTE=1200
# COLLAB_WS_RATE_LIMIT_PER_MINUTE=120
# COLLAB_BACKUP_INTERVAL_SECONDS=86400
# COLLAB_BACKUP_RETENTION_DAYS=14
# COLLAB_BACKUP_SCHEDULE_ENABLED=false
# To copy backups to an external target, mount SMB/NFS/USB on the host and set:
# COLLAB_BACKUP_EXPORT_PATH=/mnt/collab-backups
# COLLAB_BACKUP_EXPORT_DIR=/backup-export
# Leave unset to use the built-in Compose admin UI backup/restore hooks.
# Set to an empty value or a custom command to disable/replace the built-ins.
# COLLAB_BACKUP_COMMAND=
# COLLAB_RESTORE_COMMAND=
COLLAB_LOG_FORMAT=json
COLLAB_LOG=collab_server=info,tower_http=info
