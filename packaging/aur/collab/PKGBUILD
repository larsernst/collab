# Maintainer: Azazel <TODO: aur-email>

pkgname=collab
pkgver=0.6.5
pkgrel=1
pkgdesc="Local-first Markdown workspace with notes, canvases, Kanban, PDFs, and sync"
arch=('x86_64')
url="https://github.com/Azazel55605/collab"
license=('MIT')
depends=(
  'cairo'
  'gdk-pixbuf2'
  'glib2'
  'gtk3'
  'hicolor-icon-theme'
  'libsecret'
  'libsoup3'
  'pango'
  'webkit2gtk-4.1'
)
makedepends=(
  'appmenu-gtk-module'
  'cargo'
  'desktop-file-utils'
  'libappindicator-gtk3'
  'librsvg'
  'nodejs'
  'openssl'
  'pkgconf'
  'pnpm'
)
checkdepends=('appstream')
options=('!lto')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/desktop-v${pkgver}.tar.gz")
sha256sums=('TODO_REPLACE_WITH_RELEASE_TARBALL_SHA256')

prepare() {
  cd "${pkgname}-desktop-v${pkgver}"

  export CARGO_HOME="${srcdir}/cargo-home"
  export CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse
  export PNPM_HOME="${srcdir}/pnpm-home"

  pnpm config set store-dir "${srcdir}/pnpm-store"
  pnpm fetch --frozen-lockfile
  cargo fetch --locked
}

build() {
  cd "${pkgname}-desktop-v${pkgver}"

  export CARGO_HOME="${srcdir}/cargo-home"
  export CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse
  export PNPM_HOME="${srcdir}/pnpm-home"
  export TAURI_SIGNING_PRIVATE_KEY=

  pnpm install --frozen-lockfile --offline
  pnpm tauri build --no-bundle
}

check() {
  cd "${pkgname}-desktop-v${pkgver}"

  desktop-file-validate flatpak/com.azazel.collab.desktop
  appstreamcli validate --no-net flatpak/com.azazel.collab.metainfo.xml
}

package() {
  cd "${pkgname}-desktop-v${pkgver}"

  install -Dm755 "target/release/collab" "${pkgdir}/usr/bin/collab"
  install -Dm644 "flatpak/com.azazel.collab.desktop" \
    "${pkgdir}/usr/share/applications/com.azazel.collab.desktop"
  install -Dm644 "flatpak/com.azazel.collab.metainfo.xml" \
    "${pkgdir}/usr/share/metainfo/com.azazel.collab.metainfo.xml"
  install -Dm644 "src-tauri/icons/32x32.png" \
    "${pkgdir}/usr/share/icons/hicolor/32x32/apps/com.azazel.collab.png"
  install -Dm644 "src-tauri/icons/128x128.png" \
    "${pkgdir}/usr/share/icons/hicolor/128x128/apps/com.azazel.collab.png"
  install -Dm644 "README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
