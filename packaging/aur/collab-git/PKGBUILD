# Maintainer: Azazel <TODO: aur-email>

_pkgname=collab
pkgname=collab-git
pkgver=0.5.6.r0.g0000000
pkgrel=1
pkgdesc="Local-first Markdown workspace with notes, canvases, Kanban, PDFs, and sync (git version)"
arch=('x86_64')
url="https://github.com/Azazel55605/collab"
license=('MIT')
depends=(
  'cairo'
  'gdk-pixbuf2'
  'glib2'
  'gtk3'
  'hicolor-icon-theme'
  'libsecret'
  'libsoup3'
  'pango'
  'webkit2gtk-4.1'
)
makedepends=(
  'appmenu-gtk-module'
  'cargo'
  'desktop-file-utils'
  'git'
  'libappindicator-gtk3'
  'librsvg'
  'nodejs'
  'openssl'
  'pkgconf'
  'pnpm'
)
checkdepends=('appstream')
provides=("${_pkgname}=${pkgver}")
conflicts=("${_pkgname}")
options=('!lto')
source=("${pkgname}::git+${url}.git")
sha256sums=('SKIP')

pkgver() {
  cd "${pkgname}"

  # Prefer the most recent desktop release tag; fall back to legacy v* tags, then
  # to a 0.0.0 base if none exist.
  git describe --long --tags --abbrev=7 --match 'desktop-v[0-9]*' 2>/dev/null \
    | sed 's/^desktop-v//;s/\([^-]*-g\)/r\1/;s/-/./g' \
    || git describe --long --tags --abbrev=7 --match 'v[0-9]*' 2>/dev/null \
      | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g' \
    || printf '0.0.0.r%s.g%s' \
        "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
}

prepare() {
  cd "${pkgname}"

  export CARGO_HOME="${srcdir}/cargo-home"
  export CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse
  export PNPM_HOME="${srcdir}/pnpm-home"

  pnpm config set store-dir "${srcdir}/pnpm-store"
  pnpm fetch --frozen-lockfile
  cargo fetch --locked
}

build() {
  cd "${pkgname}"

  export CARGO_HOME="${srcdir}/cargo-home"
  export CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse
  export PNPM_HOME="${srcdir}/pnpm-home"
  export TAURI_SIGNING_PRIVATE_KEY=

  pnpm install --frozen-lockfile --offline
  pnpm tauri build --no-bundle
}

check() {
  cd "${pkgname}"

  desktop-file-validate flatpak/com.azazel.collab.desktop
  appstreamcli validate --no-net flatpak/com.azazel.collab.metainfo.xml
}

package() {
  cd "${pkgname}"

  install -Dm755 "target/release/collab" "${pkgdir}/usr/bin/collab"
  install -Dm644 "flatpak/com.azazel.collab.desktop" \
    "${pkgdir}/usr/share/applications/com.azazel.collab.desktop"
  install -Dm644 "flatpak/com.azazel.collab.metainfo.xml" \
    "${pkgdir}/usr/share/metainfo/com.azazel.collab.metainfo.xml"
  install -Dm644 "src-tauri/icons/32x32.png" \
    "${pkgdir}/usr/share/icons/hicolor/32x32/apps/com.azazel.collab.png"
  install -Dm644 "src-tauri/icons/128x128.png" \
    "${pkgdir}/usr/share/icons/hicolor/128x128/apps/com.azazel.collab.png"
  install -Dm644 "README.md" "${pkgdir}/usr/share/doc/${_pkgname}/README.md"
  install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${_pkgname}/LICENSE"
}
