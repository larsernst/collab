{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Collab Companion",
  "identifier": "com.azazel.collab.companion",
  "build": {
    "beforeDevCommand": "node scripts/mobile-dev-frontend.mjs",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "node scripts/mobile-build-frontend.mjs",
    "frontendDist": "../dist-mobile"
  },
  "app": {
    "windows": [
      {
        "title": "Collab Companion",
        "width": 390,
        "height": 844,
        "minWidth": 320,
        "minHeight": 600,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "versionCode": 6006
    }
  },
  "version": "0.6.6"
}
